# Copy to .streamlit/secrets.toml for local `streamlit run` testing.
# .streamlit/secrets.toml is gitignored — never commit real secrets.
# On Streamlit Community Cloud, paste this same content (with real values)
# into: App settings -> Secrets.

OPENROUTER_API_KEY = "your_api_key_here"
MODEL = "deepseek/deepseek-v4-pro"
QA_VISION_MODEL = "qwen/qwen3.5-flash-02-23"

OPENROUTER_ONLY_PROVIDERS = ""
OPENROUTER_ALLOW_FALLBACKS = "1"
OPENROUTER_DATA_COLLECTION = "allow"

QA_USE_PIPELINE = "1"
QA_SKIP_SPELL = "0"
QA_SELF_REVIEW = "0"
QA_PARALLEL = "1"

# Leave empty on Linux (Streamlit Cloud) — tesseract-ocr from packages.txt is on PATH.
TESSERACT_CMD = ""

LOG_LEVEL = "INFO"
