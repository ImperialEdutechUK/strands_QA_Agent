# --- Required -----------------------------------------------------------------
OPENROUTER_API_KEY=your_api_key_here
MODEL=deepseek/deepseek-v4-pro
# Vision model for the screenshot-based visual QA pass (bold/alignment/logos and
# double-checking that flagged text really looks wrong on the rendered page).
# Must be an image-capable OpenRouter model — deepseek models are TEXT-ONLY, so
# this is a separate slug. Leave empty to disable the vision pass.
QA_VISION_MODEL=qwen/qwen3.5-flash-02-23

# OpenRouter provider routing (see src/qa_agent/provider_policy.py).
# Default: allow ANY provider with fallbacks so requests aren't queued behind a
# saturated allow-list. Set a comma-separated list to restrict; leave empty for any.
OPENROUTER_ONLY_PROVIDERS=
# "1" (default) lets a busy provider spill to the next; "0" disables fallbacks.
OPENROUTER_ALLOW_FALLBACKS=1
# Optional privacy filter: "deny" restricts to providers that do NOT log/retain
# prompts (smaller pool, may queue). Leave unset/"allow" for the widest pool.
OPENROUTER_DATA_COLLECTION=allow

# --- Run mode -------------------------------------------------------------------
# "1" (default): deterministic pipeline — the QA tools run directly in code with
# no orchestrator LLM and no MCP round-trip. Cheapest and most reliable: only the
# analytical LLM calls (template parse, spell, spec extract, compliance) remain,
# and the report is assembled in code so nothing is paraphrased or invented.
# "0": route through the Strands agent + MCP server (needs the MCP server running).
QA_USE_PIPELINE=1
# "1" to skip the full-page spelling/grammar LLM pass (template-rule compliance
# still runs). Saves one large LLM call per run.
QA_SKIP_SPELL=0
# "1" to run the LLM self-review (`reason`) step. Its verdict is logs-only (it is
# stripped from the report), so it is OFF by default to save the call.
QA_SELF_REVIEW=0
# "1" (default): run independent pipeline stages concurrently (page extraction ∥
# template parse ∥ reference-page extraction, then spell ∥ spec lookup ∥ vision).
# Every stage gets exactly the same inputs as the serial order, so the findings
# are identical — the run is just much faster. Set "0" to serialize (debugging,
# or if concurrent LLM calls keep hitting the provider's rate limit).
QA_PARALLEL=1
# Pages longer than this many characters are spell-checked in parallel
# paragraph-boundary chunks (more reliable than one giant LLM call, and faster).
QA_SPELL_CHUNK_CHARS=28000
QA_SPELL_MAX_WORKERS=3

# --- MCP server ---------------------------------------------------------------
MCP_HOST=127.0.0.1
MCP_PORT=3001
MCP_URL=http://127.0.0.1:3001/mcp
# Set a strong random value (e.g. `python -c "import secrets;print(secrets.token_urlsafe(32))"`)
# to require bearer-token auth on every MCP tool call. Leave blank to disable (loopback only).
MCP_AUTH_TOKEN=

# --- Optional infra -----------------------------------------------------------
# Explicit path to tesseract.exe (Windows). Leave empty if it is on PATH.
TESSERACT_CMD=

# --- Limits (override only if you know what you are doing) --------------------
QA_MAX_TEXT_BYTES=65536
QA_MAX_IMAGE_BYTES=10485760
QA_MAX_HTTP_RESPONSE_BYTES=2097152
# Pathsep-separated list of directories template images may be loaded from.
QA_TEMPLATE_DIRS=

# --- Logging ------------------------------------------------------------------
LOG_LEVEL=INFO
